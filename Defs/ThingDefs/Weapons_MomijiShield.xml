<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="ApparelBase">
    <defName>Momiji_Shield</defName>
    <label>天狗盾牌</label>
    <description>白狼天狗使用的轻便盾牌，装备后可以获得看见千里之外程度的能力。</description>
    <thingClass>Apparel</thingClass>
    <graphicData>
      <texPath>Items/Momiji_Shield</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>

    <!-- 材料 -->
    <costList>
      <Crimsongold>50</Crimsongold>
    </costList>

    <recipeMaker>
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <workAmount>2500</workAmount>
      <recipeUsers>
        <li>TableHifuuClub</li>
      </recipeUsers>
    </recipeMaker>

    <statBases>
      <MarketValue>500</MarketValue>
      <Mass>2.0</Mass>
      <MaxHitPoints>500</MaxHitPoints>
      <Flammability>0.2</Flammability>

      <ArmorRating_Sharp>1.0</ArmorRating_Sharp>
      <ArmorRating_Blunt>1.2</ArmorRating_Blunt>
	  <ArmorRating_Heat>0.5</ArmorRating_Heat>
    </statBases>

    <equippedStatOffsets>
      <ShootingAccuracyPawn>0.25</ShootingAccuracyPawn>
    </equippedStatOffsets>

    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
        <li>Waist</li>
      </bodyPartGroups>
      <layers>
        <li>Touhou_AccessoryOuter</li>
      </layers>
      <wornGraphicPath>Items/Momiji_Shield</wornGraphicPath>
      <tags>
        <li>Shield</li>
      </tags>
    </apparel>

    <!-- 组件：装备时添加健康状态 -->
    <comps>
      <li Class="TouhouExpansion.CompProperties_EquippableHediff">
        <hediffDef>Momiji_MountainEyes</hediffDef>
      </li>
    </comps>

    <!-- 交易标签 -->
    <thingSetMakerTags>
      <li>RewardStandard</li>
    </thingSetMakerTags>
    <tradeTags>
      <li>ExoticMisc</li>
    </tradeTags>

    <!-- 熔炼 -->
    <smeltable>true</smeltable>
    <smeltProducts>
      <Crimsongold>10</Crimsongold>
    </smeltProducts>
  </ThingDef>
</Defs>