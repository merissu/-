<Defs>
<ThingDef ParentName="ResourceBase">
	<defName>Crimsongold</defName>
	<label>绯绯色金</label>
	<description>绯绯色金，是记载于竹内文献的神秘金属，用超古代科技铸造，会发出火焰般炫目光芒，决不生锈且含有神秘力量的合金。

绯绯色金适合制作各种魔法用具,例如魔理沙的八卦炉中就掺入了绯绯色金,传说中的草薙之剑也是用绯绯色金铸成的。</description>
	<tradeability>Sellable</tradeability>
	<graphicData>
		<texPath>Material/Crimsongold</texPath>
		<graphicClass>Graphic_StackCount</graphicClass>
	</graphicData>
	<equippedAngleOffset>20</equippedAngleOffset>
	<soundInteract>Metal_Drop</soundInteract>
	<soundDrop>Metal_Drop</soundDrop>
	<useHitPoints>false</useHitPoints>
	<healthAffectsPrice>false</healthAffectsPrice>
	<statBases>
		<MarketValue>50</MarketValue>
		<Mass>0.25</Mass>
		<StuffPower_Armor_Sharp>1.5</StuffPower_Armor_Sharp>
		<StuffPower_Armor_Blunt>1.5</StuffPower_Armor_Blunt>
		<StuffPower_Armor_Heat>0.5</StuffPower_Armor_Heat>
		<StuffPower_Insulation_Cold>-5</StuffPower_Insulation_Cold>
		<StuffPower_Insulation_Heat>-5</StuffPower_Insulation_Heat>
		<SharpDamageMultiplier>2.7</SharpDamageMultiplier>
		<BluntDamageMultiplier>1.4</BluntDamageMultiplier>
	</statBases>
	<thingCategories>
		<li>ResourcesRaw</li>
	</thingCategories>
	<stackLimit>75</stackLimit>
	<deepCommonality>1</deepCommonality>
	<deepCountPerPortion>4</deepCountPerPortion>
	<deepLumpSizeRange>2~3</deepLumpSizeRange>
	<burnableByRecipe>false</burnableByRecipe>
	<smeltable>true</smeltable>
	<stuffProps>
		<categories>
			<li>Metallic</li>
		</categories>
		<appearance>Metal</appearance>
		<commonality>0.05</commonality>
		<constructEffect>ConstructMetal</constructEffect>
		<color>(255,155,51)</color>
		<soundMeleeHitSharp>MeleeHit_Metal_Sharp</soundMeleeHitSharp>
		<soundMeleeHitBlunt>MeleeHit_Metal_Blunt</soundMeleeHitBlunt>
		<statOffsets>
			<Beauty>16</Beauty>
	        <PsychicEntropyRecoveryRateOffset>0.5</PsychicEntropyRecoveryRateOffset>
	        <PsychicSensitivity>0.5</PsychicSensitivity>
		</statOffsets>
		<statFactors>
			<MaxHitPoints>5</MaxHitPoints>
			<Beauty>2.2</Beauty>
			<Flammability>0</Flammability>
			<WorkToMake>4</WorkToMake>
			<WorkToBuild>4</WorkToBuild>
			<MeleeWeapon_CooldownMultiplier>0.7</MeleeWeapon_CooldownMultiplier>
		</statFactors>
	</stuffProps>
	<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
	<allowedArchonexusCount>80</allowedArchonexusCount>
</ThingDef>

	<RecipeDef>
        <defName>Make_Crimsongold</defName>
        <label>制作绯绯色金</label>
        <description>通过注入魔力来制造绯绯色合金。</description>
        <jobString>正在制造绯绯色金。</jobString>
        <workAmount>2000</workAmount>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>  
		<effectWorking>Smelt</effectWorking> 
		<soundWorking>Recipe_Smelt</soundWorking>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Gold</li> 
					</thingDefs>
                </filter>
                <count>1</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Plasteel</li> 
					</thingDefs>
                </filter>
                <count>5</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Uranium</li> 
					</thingDefs>
                </filter>
                <count>5</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Steel</li> 
					</thingDefs>
                </filter>
                <count>5</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>PowerPoint</li>  
				    </thingDefs>
                </filter>
                <count>24</count>
            </li>
        </ingredients>
        <products>
                <Crimsongold>5</Crimsongold>
        </products>
        <skillRequirements>
            <Crafting>10</Crafting>
        </skillRequirements>
        <researchPrerequisite>PowerPoint</researchPrerequisite>
        <recipeUsers>
            <li>TableHifuuClub</li> 
		</recipeUsers>
    </RecipeDef>

