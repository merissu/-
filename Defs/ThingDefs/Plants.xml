<Defs>
	<ThingDef ParentName="DeciduousTreeBase">
		<defName>Plant_SpiritualFloweringBush</defName>
		<label>栖灵花丛</label>
		<description>可能是由于某位死神的疏忽，大量幽灵堆积在此岸，它们无处可去，便凭依在这些花上，使花不合时宜地开放，然后快速枯萎，可以在花枯萎前将其砍伐以获取栖灵木。</description>
		<graphicData>
			<texPath>Plants/Plant_SpiritualFloweringBush</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.1, 0.2, 0.1)</volume>
			</shadowData>
		</graphicData>
		<statBases>
