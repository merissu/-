<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<!--迷途笋-->
<ThingDef ParentName="PlantFoodRawBase">
	<defName>LoseBambooShoot</defName>
	<label>迷途笋</label>
	<description>迷途竹林里的笋，这种笋普通人生吃的话会中毒,但是做熟了再吃就是不可多得的美味，除此之外这种笋也可以入药。</description>
	<tradeability>Sellable</tradeability>
	<possessionCount>10</possessionCount>
		<graphicData>
			<texPath>Food/LoseBambooShoot</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
			<drawSize>(1,1)</drawSize>
		</graphicData>
	<statBases>
		<MarketValue>1.5</MarketValue>
		<Mass>0.03</Mass>
		<Nutrition>0.25</Nutrition>
	</statBases>
	<ingestible>
		<preferability>DesperateOnly</preferability>
		<foodType>VegetableOrFruit</foodType>
			<baseIngestTicks>100</baseIngestTicks>
			<chairSearchRadius>20</chairSearchRadius>
			<useEatingSpeedStat>true</useEatingSpeedStat>
			<ingestCommandString>啃{0}</ingestCommandString>
			<ingestReportString>啃{0}</ingestReportString>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>Lost</hediffDef>
					<severity>0.1</severity>
				</li>
			</outcomeDoers>
	</ingestible>
	<comps>
		<li Class="CompProperties_Rottable">
			<daysToRotStart>30</daysToRotStart>
			<rotDestroys>true</rotDestroys>
		</li>
	</comps>
</ThingDef>

<HediffDef ParentName="ChronicDiseaseBase">
	<defName>Lost</defName>
	<label>迷茫</label>
	<hediffClass>Hediff_High</hediffClass>
	<defaultLabelColor>(153,204,102)</defaultLabelColor>
	<description>这个人吃下了生的迷途笋,其中的化学物质干扰了这个人的思维,这个人可能会忘掉一些短期记忆,严重的话会陷入痴呆状态。</description>
	<comps>
		<li Class="HediffCompProperties_SeverityPerDay">
			<severityPerDay>-0.5</severityPerDay>
		</li>
	</comps>
	<scenarioCanAdd>false</scenarioCanAdd>
	<isBad>true</isBad>
	<maxSeverity>1.0</maxSeverity>
	<stages>
		<li>
			<label>轻度</label>
			<mentalStateGivers>
				<li>
					<mentalState>WanderConfused</mentalState>
					<mtbDays>6</mtbDays>
				</li>
			</mentalStateGivers>
			<forgetMemoryThoughtMtbDays>7</forgetMemoryThoughtMtbDays>
		</li>
		<li>
			<label>中度</label>
			<minSeverity>0.4</minSeverity>
			<mentalStateGivers>
				<li>
					<mentalState>WanderConfused</mentalState>
					<mtbDays>4</mtbDays>
				</li>
			</mentalStateGivers>
			<forgetMemoryThoughtMtbDays>4</forgetMemoryThoughtMtbDays>
			<pctConditionalThoughtsNullified>0.15</pctConditionalThoughtsNullified>
		</li>
		<li>
			<label>重度</label>
			<minSeverity>0.6</minSeverity>
			<mentalStateGivers>
				<li>
					<mentalState>WanderConfused</mentalState>
					<mtbDays>2</mtbDays>
				</li>
			</mentalStateGivers>
			<forgetMemoryThoughtMtbDays>2</forgetMemoryThoughtMtbDays>
			<pctConditionalThoughtsNullified>0.33</pctConditionalThoughtsNullified>
		</li>
		<li>
			<label>极重</label>
			<minSeverity>0.8</minSeverity>
			<mentalStateGivers>
				<li>
					<mentalState>WanderConfused</mentalState>
					<mtbDays>0.5</mtbDays>
				</li>
			</mentalStateGivers>
			<forgetMemoryThoughtMtbDays>1.0</forgetMemoryThoughtMtbDays>
			<pctConditionalThoughtsNullified>0.5</pctConditionalThoughtsNullified>
		</li>
	</stages>
</HediffDef>

	<ThingDef ParentName="DrugPillBase">
		<defName>HeavenlyPeach</defName>
		<label>月球桃子</label>
		<description>因为产自月球,所以是无垢的桃子,比地上的任何桃子都更加鲜美,也很适合制作去除污秽的药物。

吃下后可以去除污秽,体质也会慢慢改变,如果某人病入膏肓了,给她吃一口桃子就能立马康复,但是长时间不吃桃子的话身体依然会充满污秽。

虽然桃子很美味,但是要注意糖分的摄取哦。</description>
		<possessionCount>10</possessionCount>
		<stackLimit>30</stackLimit>
		<thingCategories>
			<li>PlantFoodRaw</li>
		</thingCategories>
		<graphicData>
			<texPath>Food/HeavenlyPeach</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
			<drawSize>(1,1)</drawSize>
		</graphicData>
		<tradeability>Sellable</tradeability>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<MarketValue>80</MarketValue>
			<Mass>0.5</Mass>
			<Nutrition>0.4</Nutrition>
			<FoodPoisonChanceFixedHuman>0</FoodPoisonChanceFixedHuman>
		</statBases>
		<tickerType>Rare</tickerType>
		<ingestible>
			<tasteThought>AteLavishMeal</tasteThought>
			<preferability>DesperateOnly</preferability>
			<foodType>VegetableOrFruit</foodType>
			<baseIngestTicks>100</baseIngestTicks>
			<chairSearchRadius>20</chairSearchRadius>
			<useEatingSpeedStat>true</useEatingSpeedStat>
			<ingestCommandString>吃掉{0}</ingestCommandString>
			<ingestReportString>吃掉{0}</ingestReportString>
		    <ingestSound>Merissu_E_HiPotion</ingestSound>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>HeavenlyPeach</hediffDef>
					<severity>1</severity>
				</li>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>HeavenlyPeachAddiction</hediffDef>
					<severity>0.1</severity>
				</li>
			</outcomeDoers>
		</ingestible>
		<comps>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>30</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
			<li Class="CompProperties_Drug">
				<chemical>HeavenlyPeach</chemical>
				<addictiveness>0</addictiveness>
				<existingAddictionSeverityOffset>0.05</existingAddictionSeverityOffset>
				<needLevelOffset>0.05</needLevelOffset>
				<isCombatEnhancingDrug>false</isCombatEnhancingDrug>
				<listOrder>100</listOrder>
				<overdoseSeverityOffset>0</overdoseSeverityOffset>
				<largeOverdoseChance>0</largeOverdoseChance>
			</li>
		</comps>
	</ThingDef>

	<HediffDef>
		<defName>HeavenlyPeach</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>无垢</label>
		<defaultLabelColor>(204,204,102)</defaultLabelColor>
		<description>你感到体内的污秽正在被去除。</description>
		<isBad>false</isBad>
		<maxSeverity>1.0</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-4</severityPerDay>
