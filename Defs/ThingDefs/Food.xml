		</stages>
	</HediffDef>
	
		<ChemicalDef>
			<defName>HeavenlyPeach</defName>
			<label>HeavenlyPeach</label>
			<addictionHediff>HeavenlyPeachAddiction</addictionHediff>
		</ChemicalDef>

