			<Ability_EffectRadius>10</Ability_EffectRadius>
		</statBases>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<warmupTime>0.5</warmupTime>
			<range>99</range>
			<drawAimPie>true</drawAimPie>
