<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<AbilityDef>
		<defName>FourOfAKind</defName>
		<label>禁忌「四重存在」</label>
        <abilityClass>merissu.Ability_InfraredMoon</abilityClass>
		<description>芙兰分身后肆无忌惮地发动攻击的符卡。我一直都觉得分身以后会变得无所不能,而且我也想要奴隶。

使用需要消耗一层灵力,分身会存在六小时</description>
		<iconPath>Abilities/FourOfAKind</iconPath>
		<cooldownTicksRange>15000</cooldownTicksRange>
		<writeCombatLog>True</writeCombatLog>
		<targetRequired>false</targetRequired>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<drawAimPie>false</drawAimPie>
			<requireLineOfSight>false</requireLineOfSight>
			<nonInterruptingSelfCast>true</nonInterruptingSelfCast>
			<warmupTime>1</warmupTime>
            <soundCast>spell</soundCast>
			<range>49.5</range>
			<targetable>false</targetable>
			<targetParams>
				<canTargetSelf>True</canTargetSelf>
			</targetParams>
		</verbProperties>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>merissu.CompAbilityEffect_Spawner</compClass>
				<hediffDef>TheLiberationOfTheId</hediffDef>
				<psychic>false</psychic>
			</li>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>OntologyFourOfAKind</hediffDef>
				<onlyApplyToSelf>True</onlyApplyToSelf>
				<severity>1</severity>
				<replaceExisting>True</replaceExisting>
			</li>
		</comps>
	</AbilityDef>

	<HediffDef>
		<defName>OntologyFourOfAKind</defName>
		<defaultLabelColor>(255,255,204)</defaultLabelColor>
		<hediffClass>HediffWithComps</hediffClass>
		<label>禁忌「四重存在」</label>
		<description>毁灭一切的吸血鬼</description>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-4</severityPerDay>
				<showHoursToRecover>true</showHoursToRecover>
			</li>
            <li Class="merissu.HediffCompProperties_PlayMusicOnce">
                <songDef>Flandre1</songDef>
            </li>
		</comps>
		<isBad>false</isBad>
	</HediffDef>

	<HediffDef>
		<defName>FourOfAKind</defName>
		<defaultLabelColor>(255,255,204)</defaultLabelColor>
		<hediffClass>HediffWithComps</hediffClass>
