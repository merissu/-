			<li>WeaponMelee</li>
		</tradeTags>
		<defName>LaevatainF</defName>
		<label>掌中的破坏者</label>
		<description>芙兰朵露经常使用的S形武器,拿在手中便会拥有将一切悉数破坏程度的能力,让分身拿上这把武器肆无忌惮地发动攻击吧</description>
		<destroyOnDrop>true</destroyOnDrop>
		<tradeability>None</tradeability>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Weapons/Laevatain</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1,1)</drawSize>
		</graphicData>
		<relicChance>17</relicChance>
		<equippedAngleOffset>-65</equippedAngleOffset>
		<tools>
			<li>
				<label>莱瓦汀</label>
