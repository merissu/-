    <HediffDef>
        <defName>DreamHeavenlyInvincible</defName>
        <label>梦想天生</label>
        <defaultLabelColor>(255,204,102)</defaultLabelColor>
        <hediffClass>HediffWithComps</hediffClass>
        <description>总之是究极奥义。灵梦漂浮于所有物体中间变成了无敌。</description>
        <isBad>false</isBad>
        <stages>
            <li>
