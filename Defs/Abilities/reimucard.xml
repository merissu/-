    <AbilityDef>
		<defName>EightDragonSlayerArray</defName>
		<label>神技「八方鬼缚阵」</label>
        <abilityClass>merissu.Ability_EightDragonSlayerArray</abilityClass>
		<description>制成将靠近者和子弹全部阻挡的大结界,在以施法者为中心的广范围内进行攻击,会一个不漏地回击跳进来的敌人

会束缚并绞杀阵法中的所有敌人,释放时施法者也无法移动</description>
		<iconPath>Abilities/BafangDragonArray</iconPath>
		<cooldownTicksRange>800</cooldownTicksRange>
		<displayOrder>200</displayOrder>
		<aiCanUse>true</aiCanUse>
		<targetRequired>false</targetRequired>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>10</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>EightDragonCasterLock</soundCast>
            <targetParams>
                <canTargetSelf>true</canTargetSelf>
            </targetParams>
		</verbProperties>
	</AbilityDef>

	<HediffDef>
        <defName>EightDragonCasterLock</defName>
		<label>八方鬼缚阵</label>
        <defaultLabelColor>(255,204,102)</defaultLabelColor>
        <description>通过符札来限制对手行动的符卡。通过符札将对手束缚然后再慢慢绞杀。</description>
        <hediffClass>HediffWithComps</hediffClass>
        <comps>
            <li Class="merissu.HediffCompProperties_DisableMove"/>
            <li Class="merissu.HediffCompProperties_PlayMusicOnce">
                <songDef>reimu4</songDef>
            </li>
        </comps>
    </HediffDef>

    <HediffDef>
        <defName>EightDragonBurnLock</defName>
		<label>八方鬼缚阵束缚中</label>
        <defaultLabelColor>(255,0,0)</defaultLabelColor>
        <description>通过符札来限制对手行动的符卡。通过符札将对手束缚然后再慢慢绞杀。</description>
		<hediffClass>HediffWithComps</hediffClass>
        <isBad>true</isBad>
        <tendable>false</tendable>
		<maxSeverity>1.0</maxSeverity>
		<stages>
        <li>
            <capMods>
                <li>
                    <capacity>Moving</capacity>
                    <setMax>0</setMax> </li>
            </capMods>
        </li>
        </stages>
        <comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-48</severityPerDay>
			</li>
            <li Class="merissu.HediffCompProperties_DisableMove"/>
        </comps>
    </HediffDef>

