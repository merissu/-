<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <HediffDef>
        <defName>sakuyacard</defName>
        <label>怀表装备中</label>
        <defaultLabelColor>(204,204,204)</defaultLabelColor>
        <description>装备了这块怀表,你感到时间的流逝变慢了</description>
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <tendable>false</tendable>
		<maxSeverity>1.0</maxSeverity>
        <abilities>
			<li>sakuyaspell</li>
			<li>SakuyaTheWorld</li>
		</abilities>
    </HediffDef>

    <AbilityDef>
        <defName>sakuyaspell</defName>
        <label>符卡宣言</label>
        <description>进行符卡宣言,宣言后可以使用三张咲夜的强力符卡</description>
        <abilityClass>merissu.SakuyaCard</abilityClass>
        <cooldownTicksRange>1200</cooldownTicksRange>
		<displayOrder>1</displayOrder>
        <aiCanUse>false</aiCanUse>
		<targetRequired>false</targetRequired>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
			<drawAimPie>false</drawAimPie>
			<requireLineOfSight>false</requireLineOfSight>
            <warmupTime>1</warmupTime>
            <soundCast>spell</soundCast>
			<targetable>false</targetable>
            <targetParams>
                <canTargetSelf>true</canTargetSelf>
            </targetParams>
        </verbProperties>
        <iconPath>Abilities/sakuyacard</iconPath>
    </AbilityDef>

    <HediffDef>
        <defName>SakuyaCard</defName>
        <label>符卡宣言</label>
        <defaultLabelColor>(204,204,204)</defaultLabelColor>
        <description>已进行符卡宣言,在音乐结束前释放符卡吧。</description>
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <tendable>false</tendable>
		<maxSeverity>1.0</maxSeverity>
        <abilities>
			<li>EternalMeek</li>
            <li>NightFogPhantomKiller</li>
            <li>SakuyaPrivateSquare</li>
		</abilities>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-6</severityPerDay>
				<showHoursToRecover>true</showHoursToRecover>
			</li>
            <li Class="merissu.HediffCompProperties_PlayMusicOnce">
                <songDef>sakuya1</songDef>
            </li>
		</comps>
    </HediffDef>

    <AbilityDef>
        <defName>SakuyaPrivateSquare</defName>
        <label>时符「个人空间」</label>
        <description>咲夜得意的时间操作符卡之一，这张卡的作用是延缓周围的时间，减慢对手的速度从而达到攻防方面的绝对优势

使用需要消耗一层灵力,发动后,让时间减缓五倍,持续时间一小时,使用者不会受到影响</description>
        <abilityClass>merissu.SakuyaPrivateSquare</abilityClass>
        <jobDef>CastAbilityOnThing</jobDef>
        <targetRequired>False</targetRequired>
        <canUseAoeToGetTargets>False</canUseAoeToGetTargets>
        <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted>
        <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted>
        <iconPath>Abilities/PrivateSquare</iconPath> 
        <cooldownTicksRange>2500</cooldownTicksRange>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <range>0.9</range>
            <warmupTime>0</warmupTime>
            <targetParams>
                <canTargetSelf>True</canTargetSelf>
            </targetParams>
            <soundCast>spell</soundCast>
        </verbProperties>
    </AbilityDef>

    <ThingDef>
        <defName>Sakuya_PrivateSquare</defName>
        <thingClass>merissu.PrivateSquareVisual</thingClass>
        <label>个人空间</label>
        <category>Ethereal</category>
        <tickerType>Normal</tickerType>
        <altitudeLayer>Floor</altitudeLayer> 
        <selectable>false</selectable>
        <graphicData>
            <texPath>Other/objectDa000</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>Mote</shaderType>
            <drawSize>(500,500)</drawSize> 
        </graphicData>
    </ThingDef>

    <HediffDef>
        <defName>Private</defName>
        <label>个人空间</label>
        <defaultLabelColor>(204,204,204)</defaultLabelColor>
        <hediffClass>HediffWithComps</hediffClass>
        <description>让周围时间的流速长时间减缓，接近停止。</description>
        <isBad>false</isBad>
		<maxSeverity>1.0</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>2500</disappearsAfterTicks>
				<showRemainingTime>True</showRemainingTime>
			</li>
        </comps>
        <stages>
            <li>
                <statOffsets>
                    <ShootingAccuracyPawn>50</ShootingAccuracyPawn>
                    <MeleeHitChance>50</MeleeHitChance>
                    <MeleeDodgeChance>50</MeleeDodgeChance>
				    <MeleeDamageFactor>1.5</MeleeDamageFactor>
                </statOffsets>
                <capMods>
                    <li>
                        <capacity>Sight</capacity>
                        <offset>0.5</offset> </li>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.1</offset> </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>Square</defName>
        <label>女仆与血之怀表</label>
        <defaultLabelColor>(204,204,204)</defaultLabelColor>
        <hediffClass>HediffWithComps</hediffClass>
        <description>红魔馆的女仆</description>
        <isBad>false</isBad>
		<maxSeverity>1.0</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>10800</disappearsAfterTicks>
			</li>
			<li Class="merissu.HediffCompProperties_PlayMusicOnce">
                <songDef>sakuya3</songDef>
            </li>
        </comps>
    </HediffDef>

    <AbilityDef>
        <defName>SakuyaTheWorld</defName>
        <label>「咲夜的世界」</label>
        <description>操作时间的顶峰Spell之一。令周围的时间完全停止,从而进行单方面攻击的犯规级Spell。

使用需要消耗两层灵力,持续时间大概一小时,需要注意的是,时停期间其他符卡基本上无法使用,但是远程武器与近战武器依然是可以使用的

(时停时长可在设置界面自行调整)</description>
        <abilityClass>merissu.SakuyaTheWorld</abilityClass>
        <jobDef>CastAbilityOnThing</jobDef>
        <targetRequired>False</targetRequired>
        <canUseAoeToGetTargets>False</canUseAoeToGetTargets>
        <stunTargetWhileCasting>True</stunTargetWhileCasting>
        <showPsycastEffects>False</showPsycastEffects>
        <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted>
        <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted>
        <iconPath>Abilities/theworld</iconPath>
        <cooldownTicksRange>2500</cooldownTicksRange> 
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <range>0.9</range>
            <warmupTime>0</warmupTime> 
            <targetParams>
                <canTargetSelf>True</canTargetSelf>
            </targetParams>
            <soundCast>spell</soundCast> 
        </verbProperties>
    </AbilityDef>

    <HediffDef>
        <defName>the</defName>
        <label>咲夜的世界</label>
        <defaultLabelColor>(204,204,204)</defaultLabelColor>
        <hediffClass>HediffWithComps</hediffClass>
        <description>让周围时间的流速长时间减缓，甚至停止。</description>
        <isBad>false</isBad>
		<maxSeverity>1.0</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>2500</disappearsAfterTicks>
				<showRemainingTime>True</showRemainingTime>
			</li>
        </comps>
        <stages>
            <li>
                <statOffsets>
                    <ShootingAccuracyPawn>100</ShootingAccuracyPawn>
                    <MeleeHitChance>100</MeleeHitChance>
                    <MeleeDodgeChance>100</MeleeDodgeChance>
				    <MeleeDamageFactor>2</MeleeDamageFactor>
                </statOffsets>
                <capMods>
                    <li>
                        <capacity>Sight</capacity>
                        <offset>1</offset> </li>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.2</offset> </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <ThingDef>
        <defName>Sakuya_TimeStopVisual</defName>
        <thingClass>merissu.TimeStopVisual</thingClass>
        <label>时间停止</label>
