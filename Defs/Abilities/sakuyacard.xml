    <AbilityDef>
		<defName>EternalMeek</defName>
		<label>奇术「永恒的温柔」</label>
        <abilityClass>merissu.Ability_EternalMeek</abilityClass>
		<description>向前方连射大量飞刀。据说没有瞄准而是随意乱扔,可惜真伪还没人能确定。
	
散射的弹道适合清理正前方的杂兵,在近距离时会有极大的威力,使用需要消耗一层灵力。</description>
		<iconPath>Abilities/EternalMeek</iconPath>
		<cooldownTicksRange>600</cooldownTicksRange>
		<displayOrder>200</displayOrder>
		<aiCanUse>true</aiCanUse>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>30</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>spell</soundCast>
			<targetParams>
				<canTargetBuildings>true</canTargetBuildings>
				<canTargetAnimals>true</canTargetAnimals>
				<mapObjectTargetsMustBeAutoAttackable>False</mapObjectTargetsMustBeAutoAttackable>
				<canTargetMechs>true</canTargetMechs>
				<canTargetItems>False</canTargetItems>
				<canTargetSelf>false</canTargetSelf>
				<canTargetPawns>true</canTargetPawns>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
	</AbilityDef>

    <ThingDef>
        <defName>EternalMeekEmitter</defName>
        <label>永恒的温柔发射器</label>
        <thingClass>merissu.Thing_EternalMeekEmitter</thingClass>
        <category>Ethereal</category>
        <selectable>false</selectable>
        <neverMultiSelect>true</neverMultiSelect>
        <drawGUIOverlay>false</drawGUIOverlay>
        <tickerType>Normal</tickerType>
        <passability>Standable</passability>
        <altitudeLayer>MoteOverhead</altitudeLayer>
        <graphicData>
            <graphicClass>Graphic_Single</graphicClass>
            <texPath>Other/null</texPath>
            <drawSize>(0,0)</drawSize>
        </graphicData>
        <useHitPoints>false</useHitPoints>
        <destroyable>true</destroyable>
    </ThingDef>

	<ThingDef ParentName="BaseBullet">
		<defName>knife</defName>
		<label>飞刀</label>
		<thingClass>merissu.DanmakuBullet</thingClass>
		<graphicData>
			<texPath>Projectiles/knife</texPath>
			<drawSize>(1,1)</drawSize>
