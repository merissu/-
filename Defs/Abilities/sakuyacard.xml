    <HediffDef>
        <defName>world</defName>
        <label>完美潇洒</label>
        <defaultLabelColor>(204,204,204)</defaultLabelColor>
        <hediffClass>HediffWithComps</hediffClass>
        <description>完美而潇洒的从者</description>
        <isBad>false</isBad>
		<maxSeverity>1.0</maxSeverity>
