    <AbilityDef>
		<defName>NightFogPhantomKiller</defName>
		<label>幻符「杀人玩偶」</label>
        <abilityClass>merissu.Ability_NightFogPhantomKiller</abilityClass>
		<description>向周围撒开匕首并向敌人蜂拥而去的攻击,对单一目标造成极高的伤害。
	
向周围放出的小刀能准确地朝对手袭击,不仅威力高,准度也很优秀。使用需要消耗一层灵力。</description>
		<iconPath>Abilities/sakuyaKiller</iconPath>
		<cooldownTicksRange>600</cooldownTicksRange>
		<displayOrder>200</displayOrder>
		<aiCanUse>true</aiCanUse>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>30</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>spell</soundCast>
			<targetParams>
				<canTargetBuildings>False</canTargetBuildings>
				<canTargetAnimals>true</canTargetAnimals>
				<mapObjectTargetsMustBeAutoAttackable>False</mapObjectTargetsMustBeAutoAttackable>
				<canTargetMechs>true</canTargetMechs>
				<canTargetItems>False</canTargetItems>
				<canTargetSelf>false</canTargetSelf>
				<canTargetPawns>true</canTargetPawns>
				<canTargetLocations>False</canTargetLocations>
			</targetParams>
		</verbProperties>
	</AbilityDef>

