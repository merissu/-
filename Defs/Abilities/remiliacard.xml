    <AbilityDef>
		<defName>SpeartheGungnir</defName>
		<label>神枪「冈格尼尔之枪」</label>
        <abilityClass>merissu.Ability_SpeartheGungnir</abilityClass>
		<description>向前方将灵气收束成枪状投掷而出。贯通力和威力极高,会毫无阻碍的贯穿路径上的任何东西。花样繁多的枪状灵气系技能之一
	
使用需要消耗一层灵力,被击中时与其说是被弹幕打中,还不如说是被枪扎了一般。以强大的力量将弹幕投掷而出就能达到这种效果。</description>
		<iconPath>Abilities/SpeartheGungnir</iconPath>
		<cooldownTicksRange>600</cooldownTicksRange>
		<displayOrder>200</displayOrder>
		<aiCanUse>true</aiCanUse>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>999</range>
			<warmupTime>0.5</warmupTime>
			<soundCast>Spear</soundCast>
			<requireLineOfSight>false</requireLineOfSight>
			<targetParams>
				<canTargetBuildings>true</canTargetBuildings>
				<canTargetAnimals>true</canTargetAnimals>
				<mapObjectTargetsMustBeAutoAttackable>False</mapObjectTargetsMustBeAutoAttackable>
				<canTargetMechs>true</canTargetMechs>
				<canTargetItems>False</canTargetItems>
				<canTargetSelf>false</canTargetSelf>
				<canTargetPawns>true</canTargetPawns>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
	</AbilityDef>

