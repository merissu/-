    <AbilityDef>
        <defName>youmuClone</defName>
        <label>魂魄「幽明求闻持聪明之法」</label>
        <description>创造一个模仿本人行动的半身,半身拥有与本体相同的属性和能力,一段时间后消失

需要消耗一层灵力,半身不会承受伤害,并且会主动帮助本体战斗,持续存在三小时后消失</description>
        <abilityClass>merissu.Ability_YoumuClone</abilityClass>
        <cooldownTicksRange>7200</cooldownTicksRange>
		<displayOrder>200</displayOrder>
        <aiCanUse>false</aiCanUse>
		<targetRequired>false</targetRequired>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
			<drawAimPie>false</drawAimPie>
			<requireLineOfSight>false</requireLineOfSight>
            <warmupTime>1</warmupTime>
            <soundCast>spell</soundCast>
			<targetable>false</targetable>
            <targetParams>
                <canTargetSelf>true</canTargetSelf>
            </targetParams>
        </verbProperties>
        <iconPath>Abilities/youmuClone</iconPath>
    </AbilityDef>

	<HediffDef>
		<defName>youmuClone</defName>
		<label>半灵</label>
		<description>半灵状态。</description>
		<hediffClass>merissu.Hediff_YoumuShadow</hediffClass>
		<defaultLabelColor>(0.6, 0.8, 1.0)</defaultLabelColor>
		<isBad>false</isBad>
		<stages>
		<li>
			<statFactors>
				<IncomingDamageFactor>0</IncomingDamageFactor>
			</statFactors>
			<becomeVisible>false</becomeVisible> 
		</li>
		</stages>
		<comps>
		<li Class="HediffCompProperties_Disappears">
