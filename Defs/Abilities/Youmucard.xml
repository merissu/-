<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <AbilityDef>
        <defName>Youmucard</defName>
        <label>符卡宣言</label>
        <description>符卡系的技能初次使用时要进行宣言,在有效时间内再使用进行发动,虽然是一次性使用却是强力的必杀技。

进行符卡宣言时要有至少一层灵力(灵力通过满P注入),宣言后可以使用三张妖梦的强力符卡和极其强大的Last Word</description>
        <abilityClass>merissu.Youmucard</abilityClass>
        <iconPath>Abilities/Youmucard</iconPath>
        <cooldownTicksRange>300</cooldownTicksRange>
		<displayOrder>1</displayOrder>
        <aiCanUse>false</aiCanUse>
		<targetRequired>false</targetRequired>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
			<drawAimPie>false</drawAimPie>
			<requireLineOfSight>false</requireLineOfSight>
            <warmupTime>1</warmupTime>
            <soundCast>spell</soundCast>
			<targetable>false</targetable>
            <targetParams>
                <canTargetSelf>true</canTargetSelf>
            </targetParams>
        </verbProperties>
    </AbilityDef>

    <HediffDef>
        <defName>Youmucard</defName>
        <label>符卡宣言</label>
        <description>已进行符卡宣言,在音乐结束前释放符卡吧</description>
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <tendable>false</tendable>
		<maxSeverity>1.0</maxSeverity>
        <abilities>
			<li>Youmuparry</li>
			<li>youmuClone</li>
			<li>sakuraflash</li>
			<li>youmulastspell</li>
        </abilities>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-8</severityPerDay>
				<showHoursToRecover>true</showHoursToRecover>
			</li>
            <li Class="merissu.HediffCompProperties_PlayMusicOnce">
                <songDef>Youmu1</songDef>
            </li>
		</comps>
    </HediffDef>

    <AbilityDef>
        <defName>Youmuparry</defName>
        <label>剑伎「反射下界斩」</label>
        <description>使用楼观剑弹回袭来弹幕的剑伎,没有灵力加持,靠人类的体质是无法做到的。

消耗一层灵力,在接下来三个小时可以用楼观剑反弹任何弹幕</description>
        <abilityClass>merissu.Ability_Youmuparry</abilityClass>
        <cooldownTicksRange>2400</cooldownTicksRange>
		<displayOrder>200</displayOrder>
        <aiCanUse>false</aiCanUse>
		<targetRequired>false</targetRequired>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
			<drawAimPie>false</drawAimPie>
			<requireLineOfSight>false</requireLineOfSight>
            <warmupTime>1</warmupTime>
            <soundCast>spell</soundCast>
			<targetable>false</targetable>
            <targetParams>
                <canTargetSelf>true</canTargetSelf>
            </targetParams>
        </verbProperties>
        <iconPath>Abilities/Youmuparry</iconPath>
		<comps>
			<li Class="CompProperties_AbilityGiveHediff">
				<compClass>CompAbilityEffect_GiveHediff</compClass>
				<hediffDef>Youmuparry</hediffDef>
				<onlyApplyToSelf>True</onlyApplyToSelf>
				<severity>1</severity>
				<replaceExisting>True</replaceExisting>
			</li>
		</comps>
    </AbilityDef>

