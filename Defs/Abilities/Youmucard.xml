    <AbilityDef>
        <defName>sakuraflash</defName>
        <label>剑伎「樱花闪闪」</label>
        <description>向前方高速移动，一瞬之后轨道上将布满樱色的剑闪。十分华丽的剑技，也有说这是从修剪庭院领会而来，洋溢着生活感的技巧

使用需要消耗一层灵力,发动后会快速突击到目标地点并且对路径上的所有敌人造成高额伤害。</description>
        <cooldownTicksRange>0</cooldownTicksRange>
		<displayOrder>200</displayOrder>
        <aiCanUse>false</aiCanUse>
		<targetRequired>true</targetRequired>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
			<drawAimPie>false</drawAimPie>
			<requireLineOfSight>true</requireLineOfSight>
            <warmupTime>0.1</warmupTime>
            <soundCast>spell</soundCast>
			<range>30</range>
            <targetParams>
                <canTargetSelf>false</canTargetSelf>
             	<canTargetAnimals>true</canTargetAnimals>
				<canTargetPawns>true</canTargetPawns>
				<canTargetMechs>true</canTargetMechs>
				<canTargetLocations>true</canTargetLocations>
            </targetParams>
        </verbProperties>
        <iconPath>Abilities/sakuraflash</iconPath>
		<comps>
			<li Class="merissu.CompProperties_SakuraFlash"/>
		</comps>
    </AbilityDef>

