<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <DamageDef ParentName="Bite">
    <defName>Momiji_TenguBite</defName>
    <label>天狗之噬</label>
    <!-- 继承 Bite 的所有属性，只需添加附加 Hediff -->
    <additionalHediffs>
      <li>
        <hediff>Momiji_TenguBiteHediff</hediff>
        <severityPerDamageDealt>0.0167</severityPerDamageDealt>
        <!-- 设计是砍一刀增加一层的buff，因为一刀的伤害从15变成了6，所以每点伤害对应的严重程度从0.0067改成0.0167 -->
        <victimSeverityScalingByInvBodySize>false</victimSeverityScalingByInvBodySize>
      </li>
    </additionalHediffs>
  </DamageDef>
</Defs>
