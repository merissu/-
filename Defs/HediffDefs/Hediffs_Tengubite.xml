<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>Momiji_TenguBiteHediff</defName>
    <label>天狗之噬</label>
    <description>这个生物的肉体和灵魂的一部分都被天狗吞噬了。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <tendable>false</tendable>
    <maxSeverity>1.0</maxSeverity>
    <scenarioCanAdd>true</scenarioCanAdd>
    <comps>
      <!-- 每天减少 10，相当于每 10 秒减少 0.1（10 秒掉一层） -->
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-0.1</severityPerDay>
      </li>
    </comps>
    <stages>
      <!-- 阶段 0: 0.01～0.1 -->
      <li><minSeverity>0.01</minSeverity> <label>10%</label><capMods><li><capacity>Consciousness</capacity><offset>-0.05</offset></li><li><capacity>Moving</capacity><offset>-0.05</offset></li><li><capacity>Manipulation</capacity><offset>-0.05</offset></li></capMods><statFactors><IncomingDamageFactor>1.2</IncomingDamageFactor></statFactors></li>
      <!-- 阶段 1: 0.11～0.2 -->
      <li><minSeverity>0.11</minSeverity> <label>20%</label><capMods><li><capacity>Consciousness</capacity><offset>-0.10</offset></li><li><capacity>Moving</capacity><offset>-0.10</offset></li><li><capacity>Manipulation</capacity><offset>-0.10</offset></li></capMods><statFactors><IncomingDamageFactor>1.4</IncomingDamageFactor></statFactors></li>
      <!-- 阶段 2: 0.21～0.3 -->
      <li><minSeverity>0.21</minSeverity> <label>30%</label><capMods><li><capacity>Consciousness</capacity><offset>-0.15</offset></li><li><capacity>Moving</capacity><offset>-0.15</offset></li><li><capacity>Manipulation</capacity><offset>-0.15</offset></li></capMods><statFactors><IncomingDamageFactor>1.6</IncomingDamageFactor></statFactors></li>
      <!-- 阶段 3: 0.31～0.4 -->
      <li><minSeverity>0.31</minSeverity> <label>40%</label><capMods><li><capacity>Consciousness</capacity><offset>-0.20</offset></li><li><capacity>Moving</capacity><offset>-0.20</offset></li><li><capacity>Manipulation</capacity><offset>-0.20</offset></li></capMods><statFactors><IncomingDamageFactor>1.8</IncomingDamageFactor></statFactors></li>
      <!-- 阶段 4: 0.41～0.5 -->
      <li><minSeverity>0.41</minSeverity> <label>50%</label><capMods><li><capacity>Consciousness</capacity><offset>-0.25</offset></li><li><capacity>Moving</capacity><offset>-0.25</offset></li><li><capacity>Manipulation</capacity><offset>-0.25</offset></li></capMods><statFactors><IncomingDamageFactor>2.0</IncomingDamageFactor></statFactors></li>
      <!-- 阶段 5: 0.51～0.6 -->
      <li><minSeverity>0.51</minSeverity> <label>60%</label><capMods><li><capacity>Consciousness</capacity><offset>-0.30</offset></li><li><capacity>Moving</capacity><offset>-0.30</offset></li><li><capacity>Manipulation</capacity><offset>-0.30</offset></li></capMods><statFactors><IncomingDamageFactor>2.2</IncomingDamageFactor></statFactors></li>
      <!-- 阶段 6: 0.61～0.7 -->
      <li><minSeverity>0.61</minSeverity> <label>70%</label><capMods><li><capacity>Consciousness</capacity><offset>-0.35</offset></li><li><capacity>Moving</capacity><offset>-0.35</offset></li><li><capacity>Manipulation</capacity><offset>-0.35</offset></li></capMods><statFactors><IncomingDamageFactor>2.4</IncomingDamageFactor></statFactors></li>
      <!-- 阶段 7: 0.71～0.8 -->
      <li><minSeverity>0.71</minSeverity> <label>80%</label><capMods><li><capacity>Consciousness</capacity><offset>-0.40</offset></li><li><capacity>Moving</capacity><offset>-0.40</offset></li><li><capacity>Manipulation</capacity><offset>-0.40</offset></li></capMods><statFactors><IncomingDamageFactor>2.6</IncomingDamageFactor></statFactors></li>
      <!-- 阶段 8: 0.81～0.9 -->
      <li><minSeverity>0.81</minSeverity> <label>90%</label><capMods><li><capacity>Consciousness</capacity><offset>-0.45</offset></li><li><capacity>Moving</capacity><offset>-0.45</offset></li><li><capacity>Manipulation</capacity><offset>-0.45</offset></li></capMods><statFactors><IncomingDamageFactor>2.8</IncomingDamageFactor></statFactors></li>
      <!-- 阶段 9: 0.91～1.0 -->
      <li><minSeverity>0.91</minSeverity> <label>100%</label><capMods><li><capacity>Consciousness</capacity><offset>-0.50</offset></li><li><capacity>Moving</capacity><offset>-0.50</offset></li><li><capacity>Manipulation</capacity><offset>-0.50</offset></li></capMods><statFactors><IncomingDamageFactor>3.0</IncomingDamageFactor></statFactors></li>
    </stages>
  </HediffDef>
</Defs>