<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>Momiji_MountainEyes</defName>
    <label>山中的千里眼</label>
    <description>凭借白狼天狗的优秀视力，观察战场更加清晰。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <scenarioCanAdd>true</scenarioCanAdd>
    <isBad>false</isBad>
    <stages>
      <li>
        <!-- 使用 capMods 调整能力 -->
        <capMods>
          <li>
            <capacity>Sight</capacity>
            <offset>1.0</offset>          <!-- 视觉能力 +1.0 -->
          </li>
        </capMods>
        <!-- 使用 statOffsets 调整属性 -->
        <statOffsets>
          <ShootingAccuracyPawn>0.25</ShootingAccuracyPawn>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
</Defs>