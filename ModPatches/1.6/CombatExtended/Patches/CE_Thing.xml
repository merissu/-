            <Bulk>0.02</Bulk> 
          </value>
        </Operation>

        <Operation Class="PatchOperationReplace">
          <xpath>Defs/ThingDef[defName="SpiritualWood"]/statBases/StuffPower_Armor_Sharp</xpath>
          <value>
            <StuffPower_Armor_Sharp>0.1</StuffPower_Armor_Sharp>
          </value>
        </Operation>

        <Operation Class="PatchOperationReplace">
          <xpath>Defs/ThingDef[defName="SpiritualWood"]/statBases/StuffPower_Armor_Blunt</xpath>
          <value>
            <StuffPower_Armor_Blunt>0.15</StuffPower_Armor_Blunt>
          </value>
        </Operation>

        <Operation Class="PatchOperationReplace">
          <xpath>Defs/ThingDef[defName="SpiritualWood"]/tools</xpath>
          <value>
            <tools>
              <li Class="CombatExtended.ToolCE">
                <label>栖灵木</label>
                <capacities>
                  <li>Blunt</li>
                </capacities>
                <power>5</power> 
                <cooldownTime>1.6</cooldownTime>
                <armorPenetrationBlunt>0.5</armorPenetrationBlunt>
                <linkedBodyPartsGroup>Handle</linkedBodyPartsGroup>
              </li>
            </tools>
          </value>
        </Operation>

        <Operation Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="SpiritualWood"]/statBases</xpath>
            <value>
                <StuffEffectMultiplierArmor>0.5</StuffEffectMultiplierArmor>
            </value>
        </Operation>

              <!-- 博丽御守 -->
  <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="HakureiAmulet"]/comps/li[@Class="merissu.CompProperties_HakureiShield"]</xpath>
        <value>
            <li Class="merissu.CompProperties_HakureiShield">
                <startingTicksToReset>1200</startingTicksToReset>
                <minDrawSize>2</minDrawSize>
                <maxDrawSize>2.1</maxDrawSize>
                <energyLossPerDamage>0.001</energyLossPerDamage>
                <energyOnReset>1</energyOnReset>
                <blocksRangedWeapons>false</blocksRangedWeapons>
                <fullPowerHediff>FullPower</fullPowerHediff>
                <maxSeverity>10</maxSeverity>
            </li>
        </value>
    </Operation>

